<Window x:Class="Devices.InfoPages.CountrySelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Select Country"
        Width="380"
        Height="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>

        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E263D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#35557CFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style x:Key="CountryItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">

                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="10">

                            <ContentPresenter/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#1F2A4A"/>
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#2A3A5E"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

    </Window.Resources>

    <Border Background="#0F1629"
            CornerRadius="18"
            BorderBrush="#2A3A5E"
            BorderThickness="1">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->

            <StackPanel Grid.Row="0"
                        Margin="20,20,20,0">

                <TextBlock Text="Select Country"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <TextBox x:Name="txtSearch"
                         Style="{StaticResource SearchBox}"
                         Margin="0,18,0,0"
                         TextChanged="txtSearch_TextChanged"
                         PreviewKeyDown="txtSearch_PreviewKeyDown"/>

            </StackPanel>

            <!-- Countries -->

            <ListBox Grid.Row="1"
                     x:Name="lstCountries"
                     Margin="20,16"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ItemContainerStyle="{StaticResource CountryItemStyle}"
                     SelectionChanged="lstCountries_SelectionChanged"/>

            <!-- Footer -->

            <Grid Grid.Row="2"
                  Margin="20,0,20,18">

                <Button Content="Cancel"
                        Width="100"
                        Height="42"
                        HorizontalAlignment="Right"
                        Background="#26314D"
                        Foreground="White"
                        Click="btnCancel_Click"/>

            </Grid>

        </Grid>

    </Border>

</Window>