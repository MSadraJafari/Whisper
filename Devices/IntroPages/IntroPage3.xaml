<Page x:Class="Devices.IntroPage3"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:Devices"
      mc:Ignorable="d"
      d:DesignHeight="550" d:DesignWidth="800"
      Title="IntroPage3">

    <Grid>
        <!-- Background Glow -->
        <Ellipse Width="600" Height="600" 
                 Fill="#223A7A" 
                 Opacity="0.12"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Bottom"
                 Margin="-200,0,0,-200"/>

        <!-- Main Content -->
        <StackPanel HorizontalAlignment="Center" 
                    VerticalAlignment="Top"
                    Margin="0,70,0,0">

            <!-- Title -->
            <TextBlock Text="Built For Developers"
                       FontSize="42"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>

            <!-- Subtitle -->
            <TextBlock Text="Whisper is a lightweight TCP messenger&#x0A;designed for learning, communication&#x0A;and networking experiments."
                       FontSize="18"
                       Foreground="#9CAACB"
                       TextAlignment="Center"
                       Margin="0,25,0,0"
                       LineHeight="26"
                       TextWrapping="Wrap"
                       MaxWidth="620"/>

            <!-- Features Box -->
            <Border Background="#111A2E" 
                    CornerRadius="20" 
                    Margin="0,50,0,0"
                    Padding="40,35"
                    Width="520"
                    HorizontalAlignment="Center">

                <StackPanel>
                    <TextBlock Text="Built with" 
                               FontSize="20" 
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,25"
                               HorizontalAlignment="Center"/>

                    <!-- Feature Items -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <TextBlock Text="🛠️" FontSize="26" Margin="0,2,18,0"/>
                            <TextBlock Text="Built with C#" 
                                       FontSize="19"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <TextBlock Text="🔌" FontSize="26" Margin="0,2,18,0"/>
                            <TextBlock Text="TCP Networking" 
                                       FontSize="19"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <TextBlock Text="📁" FontSize="26" Margin="0,2,18,0"/>
                            <TextBlock Text="File Transfer" 
                                       FontSize="19"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🕘" FontSize="26" Margin="0,2,18,0"/>
                            <TextBlock Text="History Management" 
                                       FontSize="19"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- Navigation Buttons -->
        <Button x:Name="btnNext"
                Content="Next ↓"
                Width="140" Height="50"
                Style="{StaticResource MainButton}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,40,40" Click="btnNext_Click"/>

        <Button x:Name="btnBack"
                Content="↑ Back"
                Width="140" Height="50"
                Style="{StaticResource MainButton}"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="40,0,0,40" Click="btnBack_Click"/>
    </Grid>
</Page>