<Page x:Class="Devices.IntroPage2"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:Devices"
      mc:Ignorable="d">

    <Grid>

        <!-- Background Glow -->

        <Ellipse Width="500"
                 Height="500"
                 Fill="#223A7A"
                 Opacity="0.15"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-150,-150,0"/>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,70,0,0">

            <TextBlock Text="Why Whisper?"
                       FontSize="42"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Built for fast and secure communication"
                       FontSize="18"
                       Foreground="#9CAACB"
                       Margin="0,15,0,0"
                       HorizontalAlignment="Center"/>

        </StackPanel>

        <!-- Cards -->

        <UniformGrid Rows="2" Columns="2" Margin="140,180,140,130">
            <!-- Card 1 - Messaging (از چپ) -->
            <Border x:Name="Card1" CornerRadius="20" Margin="15" Background="#111A2E" Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform X="-120"/>
                        <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <StackPanel Margin="25">
                    <TextBlock Text="📨" FontSize="40"/>
                    <TextBlock Text="Messaging" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,15,0,0"/>
                    <TextBlock Text="Instant real-time communication between clients." Foreground="#9CAACB" TextWrapping="Wrap" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 2 - File Transfer (از راست) -->
            <Border x:Name="Card2" CornerRadius="20" Margin="15" Background="#111A2E" Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform X="120"/>
                        <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <StackPanel Margin="25">
                    <TextBlock Text="📁" FontSize="40"/>
                    <TextBlock Text="File Transfer" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,15,0,0"/>
                    <TextBlock Text="Share files seamlessly over TCP." Foreground="#9CAACB" TextWrapping="Wrap" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 3 - History (از چپ) -->
            <Border x:Name="Card3" CornerRadius="20" Margin="15" Background="#111A2E" Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform X="-120"/>
                        <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <StackPanel Margin="25">
                    <TextBlock Text="🕘" FontSize="40"/>
                    <TextBlock Text="History" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,15,0,0"/>
                    <TextBlock Text="Automatic conversation storage." Foreground="#9CAACB" TextWrapping="Wrap" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Card 4 - TCP Engine (از راست) -->
            <Border x:Name="Card4" CornerRadius="20" Margin="15" Background="#111A2E" Opacity="0" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform X="120"/>
                        <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <StackPanel Margin="25">
                    <TextBlock Text="🔌" FontSize="40"/>
                    <TextBlock Text="TCP Engine" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,15,0,0"/>
                    <TextBlock Text="Reliable communication powered by TCP." Foreground="#9CAACB" TextWrapping="Wrap" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Button x:Name="btnNext"
                Content="Next ↓"
                Width="140"
                Height="50"
                Style="{StaticResource MainButton}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,40,40" Click="btnNext_Click"/>

        <Button x:Name="btnBack"
                Content="↑ Back"
                Width="140"
                Height="50"
                Style="{StaticResource MainButton}"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="40,0,0,40" Click="btnBack_Click"/>

    </Grid>

</Page>