<Page x:Class="Devices.IntroPage5"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="550"
      d:DesignWidth="800">

    <Page.Resources>
        <LinearGradientBrush x:Key="BackgroundGradient"
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#0B1020" Offset="0"/>
            <GradientStop Color="#101936" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#557CFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6A88FF"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1.05"
                                                             Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1.05"
                                                             Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1"
                                                             Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1"
                                                             Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="Root" Background="{StaticResource BackgroundGradient}">

        <Ellipse Width="700"
                 Height="700"
                 Fill="#223A7A"
                 Opacity="0.18"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>

        <StackPanel x:Name="TitleStack"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,0,0,60">

            <Border x:Name="LogoElement"
                    Width="140"
                    Height="140"
                    CornerRadius="70"
                    Background="#557CFF"
                    HorizontalAlignment="Center">
                <Grid>
                    <TextBlock Text="W"
                               FontSize="88"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <TextBlock Text="Whisper"
                       FontSize="58"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,25,0,0"/>

            <TextBlock Text="نجوا"
                       FontSize="26"
                       Foreground="#A6B4FF"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>

            <TextBlock Text="Your Journey Begins Here!"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="#E0E7FF"
                       HorizontalAlignment="Center"
                       Margin="0,50,0,16"
                       TextAlignment="Center"/>

            <TextBlock Text="Fast messaging. File sharing. TCP powered."
                       FontSize="16"
                       Foreground="#8A9ABF"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,0,0,36"/>

            <UniformGrid Columns="3"
                         HorizontalAlignment="Center"
                         Margin="0,0,0,34">
                <Border Background="#19111A2E"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="16,10"
                        Margin="8">
                    <TextBlock Text="Real-Time Chat"
                               Foreground="White"
                               FontSize="14"
                               HorizontalAlignment="Center"/>
                </Border>

                <Border Background="#19111A2E"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="16,10"
                        Margin="8">
                    <TextBlock Text="File Transfer"
                               Foreground="White"
                               FontSize="14"
                               HorizontalAlignment="Center"/>
                </Border>

                <Border Background="#19111A2E"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="16,10"
                        Margin="8">
                    <TextBlock Text="TCP Powered"
                               Foreground="White"
                               FontSize="14"
                               HorizontalAlignment="Center"/>
                </Border>
            </UniformGrid>

            <Grid HorizontalAlignment="Center">
                <Border Width="300"
                        Height="80"
                        CornerRadius="20"
                        Background="#33557CFF"
                        Opacity="0.35">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28"
                                          ShadowDepth="0"
                                          Opacity="0.45"
                                          Color="#557CFF"/>
                    </Border.Effect>
                </Border>

                <Button x:Name="LaunchButton"
                        Content="Launch Whisper →"
                        Width="280"
                        Height="68"
                        FontSize="19"
                        FontWeight="SemiBold"
                        Style="{StaticResource MainButton}"
                        Click="btnLaunch_Click"
                        Margin="0,6,0,0"/>
            </Grid>
        </StackPanel>

        <Button x:Name="BackButton"
                Content="↑ Back"
                Width="140"
                Height="50"
                Style="{StaticResource MainButton}"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="40,0,0,40"
                Click="btnBack_Click"/>
    </Grid>
</Page>