<Page x:Class="Devices.IntroPage1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:Devices"
      mc:Ignorable="d">

    <Page.Resources>

        <LinearGradientBrush x:Key="BackgroundGradient"
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#0B1020" Offset="0"/>
            <GradientStop Color="#101936" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#557CFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05"
                                                        ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Background="{StaticResource BackgroundGradient}">

        <!-- Language Switch -->

        <Border HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="20"
                CornerRadius="20"
                Background="#18213F">

            <StackPanel Orientation="Horizontal">

                <Button Content="🇮🇷 فارسی"
                        Padding="15,8"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="White"/>

                <Button Content="🇺🇸 English"
                        Padding="15,8"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="White"/>

            </StackPanel>

        </Border>


        <Grid x:Name="PageContainer">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <!-- Logo -->

                <Border Width="160"
                        Height="160"
                        CornerRadius="80"
                        Background="#557CFF">

                    <Grid>

                        <TextBlock x:Name="LogoElement" Text="W"
                                   FontSize="80"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                    </Grid>

                </Border>

                <TextBlock x:Name="WhisperText" Text="Whisper"
                           FontSize="58"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,30,0,0"/>

                <TextBlock x:Name="PersianText" Text="نجوا"
                           FontSize="26"
                           Foreground="#A6B4FF"
                           HorizontalAlignment="Center"/>

                <TextBlock x:Name="ASTM" Text="A Secure TCP Messenger"
                           FontSize="18"
                           Foreground="#8F9BB3"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>

                <TextBlock x:Name="FSL" Text="Fast • Secure • Lightweight"
                           FontSize="16"
                           Foreground="#6C7AA8"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>

            </StackPanel>
            <Button x:Name="btnBack"
        Content="Exit"
        Width="140"
        Height="50"
        Style="{StaticResource MainButton}"
        HorizontalAlignment="Left"
        VerticalAlignment="Bottom"
        Margin="40,0,0,40" Click="btnBack_Click"/>
        </Grid>

        <!-- Bottom Navigation -->

        <Grid VerticalAlignment="Bottom"
              Margin="40">

            <Grid.ColumnDefinitions>

                <ColumnDefinition/>
                <ColumnDefinition/>

            </Grid.ColumnDefinitions>

            <Button x:Name="btnNext"
                    Grid.Column="1"
                    Content="Next ↓"
                    Width="130"
                    Height="50"
                    Style="{StaticResource MainButton}"
                    HorizontalAlignment="Left" Click="btnNext_Click" Margin="430,0,0,0" VerticalAlignment="Bottom"/>

        </Grid>

    </Grid>

</Page>