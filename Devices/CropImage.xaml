<Window x:Class="Devices.CropImage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile Picture"
        Width="1000"
        Height="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0B1020"
        FontFamily="Segoe UI">

    <Window.Resources>

        <LinearGradientBrush x:Key="BgBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0B1020" Offset="0"/>
            <GradientStop Color="#101936" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="RoundButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#26314D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                BorderBrush="#33FFFFFF"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33415F"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="bd"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1.04"
                                                             Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="bd"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1.04"
                                                             Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="bd"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                             To="1"
                                                             Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="bd"
                                                             Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                             To="1"
                                                             Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource RoundButton}">
            <Setter Property="Background" Value="#557CFF"/>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource BgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Left side -->
        <Border Grid.Column="0"
                Margin="20"
                CornerRadius="24"
                Background="#111A2E"
                BorderBrush="#223A7A"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="20,18,20,0">
                    <TextBlock Text="Profile Picture Crop"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Drag to move. Use the slider to zoom."
                               Margin="0,6,0,0"
                               Foreground="#8A9ABF"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="20,14,20,14"
                        Background="#0E1628"
                        CornerRadius="20"
                        BorderBrush="#35557CFF"
                        BorderThickness="1"
                        ClipToBounds="True">

                    <Grid ClipToBounds="True">
                        <Canvas x:Name="CropCanvas"
                                Background="Transparent"
                                ClipToBounds="True"
                                MouseDown="CropCanvas_MouseDown"
                                MouseMove="CropCanvas_MouseMove"
                                MouseUp="CropCanvas_MouseUp"
                                MouseLeave="CropCanvas_MouseUp"
                                MouseWheel="CropCanvas_MouseWheel">

                            <Image x:Name="imgMain"
                                   Stretch="Fill"/>
                        </Canvas>

                        <!-- centered crop guide -->
                        <Grid IsHitTestVisible="False"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch">
                            <Ellipse x:Name="CropGuide"
             Width="280"
             Height="280"
             Stroke="#557CFF"
             StrokeThickness="3"
             Fill="#00557CFF"
             HorizontalAlignment="Center"
             VerticalAlignment="Center"/>
                            <Ellipse Width="272"
             Height="272"
             Stroke="#99FFFFFF"
             StrokeThickness="1"
             StrokeDashArray="4 4"
             Fill="Transparent"
             HorizontalAlignment="Center"
             VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2"
                           Margin="20,0,20,16"
                           Text="The final crop will be centered from the guide."
                           Foreground="#6C7AA8"/>
            </Grid>
        </Border>

        <!-- Right side -->
        <Border Grid.Column="1"
                Margin="0,20,20,20"
                CornerRadius="24"
                Background="#111A2E"
                BorderBrush="#223A7A"
                BorderThickness="1">

            <Grid Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Preview"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="This is how your avatar will look."
                           Foreground="#8A9ABF"
                           TextWrapping="Wrap"/>

                <StackPanel Grid.Row="2"
                            VerticalAlignment="Center">

                    <Border Width="180"
                            Height="180"
                            CornerRadius="90"
                            ClipToBounds="True"
                            BorderBrush="#557CFF"
                            BorderThickness="3"
                            HorizontalAlignment="Center"
                            Background="#0E1628">
                        <Image x:Name="imgPreview"
                               Stretch="UniformToFill"/>
                    </Border>

                    <TextBlock Text="Zoom"
                               Margin="0,24,0,8"
                               Foreground="#B9C4E2"/>

                    <Slider x:Name="zoomSlider"
                            Minimum="1"
                            Maximum="3"
                            Value="1"
                            TickFrequency="0.1"
                            IsSnapToTickEnabled="False"
                            ValueChanged="zoomSlider_ValueChanged"/>
                </StackPanel>

                <Grid Grid.Row="3"
                      Margin="0,22,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnCancel"
                            Grid.Column="0"
                            Content="Cancel"
                            Margin="0,0,10,0"
                            Style="{StaticResource RoundButton}"
                            Click="btnCancel_Click"/>

                    <Button x:Name="btnApply"
                            Grid.Column="1"
                            Content="Apply"
                            Margin="10,0,0,0"
                            Style="{StaticResource PrimaryButton}"
                            Click="btnApply_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>