<Window x:Class="Server.AskPortDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Port"
        Width="320"
        Height="180"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#111A2E"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#557CFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="95"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Bd"
                        CornerRadius="12"
                        Background="{TemplateBinding Background}"
                        BorderBrush="#3B6CFF"
                        BorderThickness="1">

                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1"
                                        ScaleY="1"/>
                            </Border.RenderTransform>

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">

                                <Setter TargetName="Bd"
                                Property="Background"
                                Value="#6C8FFF"/>

                                <Setter TargetName="Bd"
                                Property="BorderBrush"
                                Value="#85A7FF"/>

                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>

                                            <DoubleAnimation
                                        Storyboard.TargetName="Bd"
                                        Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                        To="1.05"
                                        Duration="0:0:0.15"/>

                                            <DoubleAnimation
                                        Storyboard.TargetName="Bd"
                                        Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                        To="1.05"
                                        Duration="0:0:0.15"/>

                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>

                                            <DoubleAnimation
                                        Storyboard.TargetName="Bd"
                                        Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                        To="1"
                                        Duration="0:0:0.15"/>

                                            <DoubleAnimation
                                        Storyboard.TargetName="Bd"
                                        Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                        To="1"
                                        Duration="0:0:0.15"/>

                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>

                            </Trigger>

                            <Trigger Property="IsPressed"
                             Value="True">

                                <Setter TargetName="Bd"
                                Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96"
                                                ScaleY="0.96"/>
                                    </Setter.Value>
                                </Setter>

                                <Setter TargetName="Bd"
                                Property="Background"
                                Value="#406BEE"/>

                            </Trigger>

                            <Trigger Property="IsEnabled"
                             Value="False">

                                <Setter TargetName="Bd"
                                Property="Opacity"
                                Value="0.45"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DialogTextBox" TargetType="TextBox">

            <Setter Property="Background" Value="#0E1628"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#557CFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">

                        <Border x:Name="Bd"
                        CornerRadius="12"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">

                            <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="2"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsKeyboardFocused"
                             Value="True">

                                <Setter TargetName="Bd"
                                Property="BorderBrush"
                                Value="#7EA2FF"/>

                            </Trigger>

                            <Trigger Property="IsMouseOver"
                             Value="True">

                                <Setter TargetName="Bd"
                                Property="BorderBrush"
                                Value="#6C8FFF"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>
    </Window.Resources>
    
    <Border CornerRadius="18"
            Background="#111A2E"
            BorderBrush="#33415F"
            BorderThickness="1"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Enter server port"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"/>

            <TextBox x:Name="txtPort"
                     Grid.Row="1"
                     Margin="0,16,0,0"
                     Height="42"
                     Style="{StaticResource DialogTextBox}"
                     Background="#0E1628"
                     Foreground="White"
                     BorderBrush="#35557CFF"
                     BorderThickness="1"
                     Padding="12,8"
                     FontSize="15"/>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="Cancel"
                        Width="90"
                        Height="38"
                        Style="{StaticResource DialogButton}"
                        Margin="0,0,8,0"
                        Background="#26314D"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Cancel_Click"/>
                <Button Content="OK"
                        Width="90"
                        Style="{StaticResource DialogButton}"
                        Height="38"
                        Background="#557CFF"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Ok_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>